# Root .gitignore for CureOn project

####################
# OS files
####################
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

####################
# Python / Django
####################
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
ENV/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg
pip-wheel-metadata/
pip-log.txt

# Installer logs
install.log

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
coverage.xml
nose2-*.xml

# Django stuff:
*.log
local_settings.py
db.sqlite3
media/
staticfiles/

# Secret / env files
.env
.env.*
secrets.env

####################
# Node / frontend (Vite, Bun)
####################
node_modules/
/.pnp/
.pnp.js
/.parcel-cache/
/.turbo/
.vite/
dist/
build/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Bun lock (do NOT ignore if you intentionally commit it) — keep locked files
# If you prefer not to commit it, uncomment the next line
# bun.lockb

####################
# Editor / IDE
####################
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

####################
# OS / system
####################
~$*
~.*
# Windows shortcut / lock files
*.lnk

####################
# Logs and runtime
####################
logs/
*.log
*.pid
*.seed

####################
# Python bytecode in folders
####################
**/__pycache__/
**/*.pyc

####################
# Misc
####################
.idea/*
/.env.local
.DS_Store
Thumbs.db

# Ensure Git keeps these directories if empty (uncomment if needed)
# !/backend/migrations
